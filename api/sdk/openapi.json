{
  "openapi": "3.1.0",
  "info": {
    "title": "StudySync API",
    "version": "0.1.0",
    "description": "Generate study artifacts (flashcards, study guides, notes, practice questions, summaries, mind maps) from course material using OpenAI."
  },
  "servers": [
    {
      "url": "http://localhost:3001"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "GenerateRequest": {
        "type": "object",
        "properties": {
          "course_id": {
            "type": "string",
            "format": "uuid"
          },
          "output_format": {
            "type": "string",
            "enum": [
              "flashcards",
              "study_guide",
              "notes",
              "practice_questions",
              "summary",
              "mind_map"
            ]
          },
          "depth": {
            "type": "string",
            "enum": [
              "quick",
              "standard",
              "deep"
            ],
            "default": "standard"
          },
          "comprehension": {
            "type": "string",
            "enum": [
              "beginner",
              "intermediate",
              "advanced",
              "expert"
            ],
            "default": "intermediate"
          },
          "model": {
            "type": "string",
            "enum": [
              "gpt-4o-mini",
              "gpt-4.1-mini",
              "gpt-4o"
            ]
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "provider": {
                  "type": "string"
                },
                "source_name": {
                  "type": "string"
                },
                "source_url": {
                  "type": "string",
                  "nullable": true
                },
                "content": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 50000
                }
              },
              "required": [
                "provider",
                "source_name",
                "content"
              ],
              "additionalProperties": false
            },
            "minItems": 1,
            "maxItems": 10
          },
          "user_prompt": {
            "type": "string",
            "maxLength": 1000
          }
        },
        "required": [
          "course_id",
          "output_format",
          "sources"
        ],
        "additionalProperties": false
      },
      "CourseCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "code": {
            "type": "string",
            "maxLength": 16
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      },
      "CourseUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "code": {
            "type": "string",
            "maxLength": 16,
            "nullable": true
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          },
          "archived": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "PreferencesUpdate": {
        "type": "object",
        "properties": {
          "default_format": {
            "type": "string",
            "enum": [
              "flashcards",
              "study_guide",
              "notes",
              "practice_questions",
              "summary",
              "mind_map"
            ]
          },
          "default_depth": {
            "type": "string",
            "enum": [
              "quick",
              "standard",
              "deep"
            ]
          },
          "auto_scan_page": {
            "type": "boolean"
          },
          "cache_outputs": {
            "type": "boolean"
          },
          "spaced_repetition": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ApiKeyCreate": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "generate:read",
                "generate:write"
              ]
            },
            "minItems": 1
          },
          "rate_limit_per_min": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10000
          },
          "daily_token_quota": {
            "type": "integer",
            "minimum": 1
          }
        },
        "required": [
          "label"
        ],
        "additionalProperties": false
      },
      "CollectRequest": {
        "type": "object",
        "properties": {
          "course_id": {
            "type": "string",
            "format": "uuid"
          },
          "providers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "google_drive",
                "notion",
                "canvas",
                "moodle",
                "obsidian"
              ]
            },
            "minItems": 0,
            "maxItems": 5
          },
          "current_page_content": {
            "type": "string",
            "maxLength": 40000
          },
          "current_page_url": {
            "type": "string",
            "format": "uri"
          },
          "current_page_title": {
            "type": "string",
            "maxLength": 512
          }
        },
        "required": [
          "course_id",
          "providers"
        ],
        "additionalProperties": false
      }
    }
  },
  "paths": {
    "/v1/healthz": {
      "get": {
        "summary": "Health check",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy"
          }
        }
      }
    },
    "/v1/meta/formats": {
      "get": {
        "summary": "Describe supported formats, depths, comprehension levels, models, and limits",
        "security": [],
        "responses": {
          "200": {
            "description": "Capability descriptor"
          }
        }
      }
    },
    "/v1/generate": {
      "post": {
        "summary": "Generate a study artifact (buffered JSON response)",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated output"
          },
          "403": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "error",
                    "message",
                    "status"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "error",
                    "message",
                    "status"
                  ]
                }
              }
            }
          },
          "422": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "error",
                    "message",
                    "status"
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "error",
                    "message",
                    "status"
                  ]
                }
              }
            }
          },
          "503": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "error",
                    "message",
                    "status"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/generate/stream": {
      "post": {
        "summary": "Generate a study artifact (Server-Sent Events stream)",
        "description": "Emits `meta`, then `delta` events with raw token text, then a final `done` event with the persisted output and usage. Errors arrive as an `error` event.",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "text/event-stream"
          }
        }
      }
    },

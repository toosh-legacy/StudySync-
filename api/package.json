{
  "name": "studysync-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "tsx test/live/smoke.ts",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "openapi:dump": "tsx scripts/dump-openapi.ts",
    "sdk:generate": "tsx scripts/dump-openapi.ts && openapi-typescript sdk/openapi.json -o sdk/src/schema.d.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@notionhq/client": "^2.2.15",
    "@supabase/supabase-js": "^2.46.1",
    "@upstash/qstash": "^2.11.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "hono": "^4.6.12",
    "openai": "^4.73.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

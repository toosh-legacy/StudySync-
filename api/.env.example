# Copy to .env, or rely on the repo-root StudySync-/.env.local (the code reads
# SUPABASE_URL ?? NEXT_PUBLIC_SUPABASE_URL and the NEXT_PUBLIC_* anon key, so the
# Next.js .env.local works for the API too). The live smoke test loads .env.local.

# --- Service ---
PORT=3001
WEB_APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Upstash (rate limiting; optional, fails open if absent) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Upstash QStash (durable async jobs; optional, falls back to in-process) ---
# When set, POST /v1/generate/jobs are delivered via QStash to
# API_PUBLIC_URL + /v1/internal/generation-jobs/process (must be publicly reachable).
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Security (production) ---
# AES-256-GCM key for encrypting provider tokens at rest. 64 hex chars or 32-byte
# base64 (any other string is hashed to 32 bytes). If unset, tokens are plaintext.
#   generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
# HMAC secret for signing async-job webhooks (falls back to the service-role key).
WEBHOOK_SIGNING_SECRET=

# --- Migrations (npm run db:migrate) ---
SUPABASE_ACCESS_TOKEN=

# --- Source connectors (server-side OAuth apps) ---
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
